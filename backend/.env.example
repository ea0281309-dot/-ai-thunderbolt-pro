# Server Configuration
PORT=3001
NODE_ENV=development

# API Keys (replace with real values for production)
OPENAI_API_KEY=your_openai_api_key_here

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-url.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Deployment URLs (exposed via GET /api/deployment)
# Railway injects RAILWAY_STATIC_URL automatically in production.
# Vercel injects VERCEL_URL automatically; set NEXT_PUBLIC_FRONTEND_URL
# here so the backend can surface the frontend URL too.
NEXT_PUBLIC_FRONTEND_URL=https://your-frontend-url.vercel.app
BACKEND_URL=https://your-backend-url.up.railway.app
