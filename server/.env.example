# Environment variables for AI Thunderbolt Pro backend
# Copy this file to .env and fill in the values before running locally.
# Never commit .env – it is listed in .gitignore.

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------

# Port the Express server listens on (default: 3001)
PORT=3001

# ----------------------------------------------------------------------------
# Database  (injected automatically by Railway in production)
# ----------------------------------------------------------------------------

# PostgreSQL connection string.
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------

# Comma-separated list of allowed origins for CORS requests.
# Use * to allow all origins (not recommended in production).
# Defaults to http://localhost:3000 and http://localhost:5173 when unset.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
